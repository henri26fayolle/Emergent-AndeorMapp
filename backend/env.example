# Same Supabase project as the main webapp, but isolated game tables/buckets.
# Do not commit a real backend/.env file.

# Use the Supabase Postgres connection string for the existing Andeor/Yanature project.
# Prefer the Session Pooler URI from Supabase's Connect panel and keep sslmode=require.
SUPABASE_DB_URL="postgresql://postgres.PROJECT_REF:YOUR_DATABASE_PASSWORD@POOLER_HOST:5432/postgres?sslmode=require"

# Existing FastAPI auth. Keep private and long/random in production.
JWT_SECRET="replace-with-a-long-random-secret"

# Shared only with the main Andeor app. Used to accept main-site account sessions.
ANDEOR_GAME_BRIDGE_SECRET="change_me_shared_with_main_site"

# Seeded game admin account.
ADMIN_EMAIL="contact@henrifayolle.com"
ADMIN_PASSWORD="replace-before-production"

# Local HTTP development should keep this false. Set true for an HTTPS production deploy.
COOKIE_SECURE="false"

# Leave auto for normal use: first boot seeds empty game tables, later boots skip
# expensive catalog re-seeding when Supabase already has data.
GAME_SEED_MODE="auto"

# Optional until we decide whether to keep the Emergent AI provider.
EMERGENT_LLM_KEY=""
